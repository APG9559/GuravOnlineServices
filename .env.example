# ── Docker Compose Environment ────────────────────────────────────────────────
# Copy this file to .env and edit if you want to override defaults.
# The defaults below work out of the box for local development.

# Database
DB_USERNAME=
DB_PASSWORD=
DB_NAME=
DB_SSL=false
DB_LOGGING=false

# JWT — CHANGE THIS to a long random string in production!
JWT_SECRET=change-this-to-a-long-random-secret-string-before-deploying
JWT_EXPIRES_IN=8h

# Relying Party ID for WebAuthn/Passkey authentication (custom domain on LAN/production)
RP_ID=localhost

# The URL of your frontend (used for CORS in the backend)
# For local Docker Compose, leave as http://localhost
FRONTEND_URL=http://localhost

# Optional: Custom API URL for frontend (used during build-time)
VITE_API_URL=
